/*
 * RewriteReality — Operator UI theme (UI Toolkit / USS)
 * DESIGN.md のデザイントークンを USS 変数へ写像した正本スタイル。
 * Claude Design "RewriteReality Design System" の operator console を UXML/USS へ移植（#24）。
 * 色は必ず var(--rr-*) 参照。hex 直書きはトークン定義ブロックのみ（DESIGN.md「色はトークン参照」）。
 *
 * UI Toolkit 固有の制約（移植時の変換）:
 *  - flex の gap プロパティ非対応 → 子要素の margin で間隔を作る。
 *  - dashed ボーダー非対応 → safe-area は薄いソリット hairline で代替。
 *  - color-mix()/radial-gradient()/box-shadow 非対応 → 近い単色/枠線で代替（影は使わない方針と一致）。
 *  - 中央寄せは transform ではなく translate: プロパティを使用。
 *  - フォント Inter/JetBrains Mono は未同梱（Known Gap）。FontAsset を入れたら
 *    .rr-theme の -unity-font-definition と .rr-mono に割り当てる。現状はパネル既定フォント。
 *  - lucide アイコン非同梱 → transport/mute はテキスト字形で代替。
 */

/* ============================================================ Tokens */
.rr-theme {
    /* Brand & Accent */
    --rr-primary: #ff5c1a;          /* Live Amber: armed/live/CTA。希少に */
    --rr-primary-active: #d8480f;
    --rr-selection: #4a9ed8;        /* Selection Blue: 選択/フォーカス専用 */
    --rr-on-primary: #161512;

    /* Surfaces（暖色ダーク階調） */
    --rr-canvas: #161512;
    --rr-canvas-soft: #1c1a15;
    --rr-surface-panel: #232019;
    --rr-surface-raised: #2c2820;
    --rr-surface-inset: #121009;

    /* Hairlines */
    --rr-hairline: #353128;
    --rr-hairline-soft: #2a2720;
    --rr-hairline-strong: #454034;

    /* Text */
    --rr-text: #ece9e0;
    --rr-body: #b8b3a6;
    --rr-muted: #878275;
    --rr-muted-soft: #5e5a50;

    /* Pipeline Stages（状態表示専用） */
    --rr-stage-source: #e8b08a;
    --rr-stage-tracking: #93c9a0;
    --rr-stage-effects: #b9a6e0;
    --rr-stage-audio: #8fb8e6;
    --rr-stage-output: #d6a44a;
    --rr-stage-scene: #d98fae;

    /* Semantic */
    --rr-live: #46b888;
    --rr-record: #e2476a;
    --rr-warn: #e0a23a;

    flex-grow: 1;
    color: var(--rr-text);
    background-color: var(--rr-canvas);
    font-size: 12px;
}

/* JetBrains Mono を入れたらここに -unity-font-definition を割当て、値/座標を等幅整列 */
.rr-mono {
    -unity-text-align: middle-right;
}

.rr-divider {
    width: 1px;
    height: 20px;
    background-color: var(--rr-hairline);
    margin-left: 10px;
    margin-right: 10px;
}
.rr-spacer { flex-grow: 1; }

/* ============================================================ Shell layout */
.rr-root {
    flex-grow: 1;
    flex-direction: column;
}

/* ---------------------------------------------------------- Top bar / transport */
.rr-top-bar {
    height: 48px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    padding-left: 12px;
    padding-right: 12px;
    background-color: var(--rr-canvas);
    border-bottom-width: 1px;
    border-bottom-color: var(--rr-hairline-strong);
}
.rr-brand-group { flex-direction: row; align-items: center; }
.rr-brand-dot {
    width: 9px; height: 9px;
    border-radius: 9999px;
    background-color: var(--rr-primary);
    margin-right: 8px;
}
.rr-brand {
    color: var(--rr-text);
    -unity-font-style: bold;
    font-size: 13px;
}
.rr-brand-sub {
    color: var(--rr-muted);
    font-size: 11px;
    margin-left: 8px;
    -unity-text-align: middle-left;
}
.rr-project { color: var(--rr-muted); margin-left: 6px; }
/* ブランドがメニューであることの手がかり（App.jsx の chevron-down 相当）。 */
.rr-brand-caret { color: var(--rr-muted); font-size: 11px; margin-left: 5px; }

.rr-transport { flex-direction: row; align-items: center; }
.rr-transport-btn {
    width: 26px; height: 26px;
    -unity-text-align: middle-center;
    align-items: center;
    justify-content: center;
    color: var(--rr-body);
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-radius: 4px;
    font-size: 12px;
    margin-right: 2px;
}

/* ベクターアイコン（RrIcon・painter2D 描画）。色は継承 color を読むので親状態に追従 */
.rr-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
}
/* タイムライン track tail の mute/solo アイコン（muted・やや大きめ） */
.rr-track-icon {
    width: 15px;
    height: 15px;
    color: var(--rr-muted);
    margin-left: 4px;
}
/* mute アイコンのクリック領域（枠なし・アイコンのみ見せる・U3） */
.rr-track-mute-btn {
    width: 19px; height: 19px;
    padding: 0;
    margin-left: 4px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    align-items: center;
    justify-content: center;
}
.rr-track-mute-btn .rr-track-icon { margin-left: 0; }
.rr-transport-btn:hover { background-color: var(--rr-surface-raised); }
.rr-transport-btn--active {
    background-color: var(--rr-primary);
    color: var(--rr-on-primary);
}
.rr-time {
    color: var(--rr-body);
    font-size: 12px;
    margin-left: 8px;
    -unity-text-align: middle-left;
}

.rr-status { flex-direction: row; align-items: center; }

.rr-fps {
    color: var(--rr-text);
    font-size: 15px;
    -unity-text-align: middle-right;
    min-width: 76px;
    margin-left: 8px;
}
.rr-fps--warn { color: var(--rr-warn); }
/* 上部バー右の性能表示（App.jsx 準拠：fps 大＋ms·gc 小の 2 段・右寄せ）。 */
.rr-perf-group { flex-direction: column; align-items: flex-end; justify-content: center; }
.rr-perf-group > .rr-perf {
    margin-top: 2px;
    -unity-text-align: middle-right;
}

/* ---------------------------------------------------------- Middle: left dock / center / right dock */
.rr-mid {
    flex-grow: 1;
    flex-direction: row;
}

.rr-dock {
    flex-shrink: 0;
    flex-direction: column;
    background-color: var(--rr-surface-panel);
    border-color: var(--rr-hairline-strong);
    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 12px;
}
.rr-dock-left  { width: 210px; border-right-width: 1px; }
.rr-dock-right { width: 290px; border-left-width: 1px; }
/* ページ依存の左ドック（PERFORM=ライブラリ / MAPPING=Surfaces）・切替は OperatorUI.SelectPage */
.rr-dock-page { flex-direction: column; }
/* PERFORM ライブラリの折りたたみ（Unity Foldout・見出しは section-label 調に寄せる） */
.rr-lib-fold { margin-top: 2px; }
.rr-lib-fold .unity-foldout__content { margin-left: 6px; }
.rr-lib-fold .unity-foldout__toggle .unity-label {
    font-size: 11px;
    color: var(--rr-muted);
    -unity-font-style: bold;
    letter-spacing: 0.8px;
}
/* 旧・下部 FX ドック（現在はタイムラインに置換・互換のため残置） */
.rr-dock-bottom { height: 168px; border-top-width: 1px; }

/* Section label（ドック内の小見出し・uppercase muted） */
.rr-section-label {
    height: 26px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-left: 2px;
    padding-right: 2px;
    margin-top: 8px;
    margin-bottom: 2px;
}
.rr-section-label__text {
    color: var(--rr-muted);
    font-size: 11px;
    -unity-font-style: bold;
    -unity-text-align: middle-left;
}
.rr-add-btn {
    color: var(--rr-body);
    background-color: rgba(0, 0, 0, 0);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 4px;
    font-size: 10px;
    padding: 2px 7px;
}
.rr-add-btn:hover { background-color: var(--rr-surface-raised); }

/* List item（Surface/Input/Route などの一覧行） */
.rr-list-item {
    height: 28px;
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    border-left-width: 2px;
    border-left-color: rgba(0, 0, 0, 0);
    border-radius: 2px;
}
.rr-list-item:hover { background-color: var(--rr-surface-raised); }
.rr-list-item--active {
    background-color: var(--rr-surface-raised);
    border-left-color: var(--rr-selection);
}
.rr-list-dot {
    width: 7px; height: 7px;
    border-radius: 9999px;
    background-color: var(--rr-muted-soft);
    margin-right: 8px;
    flex-shrink: 0;
}
.rr-list-dot--source   { background-color: var(--rr-stage-source); }
.rr-list-dot--tracking { background-color: var(--rr-stage-tracking); }
.rr-list-dot--effects  { background-color: var(--rr-stage-effects); }
.rr-list-dot--audio    { background-color: var(--rr-stage-audio); }
.rr-list-dot--output   { background-color: var(--rr-stage-output); }
.rr-list-dot--scene    { background-color: var(--rr-stage-scene); }
.rr-list-dot--live     { background-color: var(--rr-live); }
.rr-list-label {
    flex-grow: 1;
    color: var(--rr-body);
    font-size: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    -unity-text-align: middle-left;
}
.rr-list-item--active .rr-list-label { color: var(--rr-text); }
.rr-list-meta {
    color: var(--rr-muted);
    font-size: 10px;
    -unity-text-align: middle-right;
    flex-shrink: 0;
}
.rr-list-label--off { color: var(--rr-muted); }

/* Surface パネル（左ドック・#22）— 一覧＋選択 surface のプロパティ */
.rr-surface-list { flex-direction: column; }
.rr-surface-empty {
    color: var(--rr-muted);
    font-size: 10px;
    padding-left: 10px; padding-right: 10px;
    padding-top: 4px; padding-bottom: 6px;
    white-space: normal;
}
/* Surface 一覧行の trailing eye/lock ボタン（U4・SurfaceInspector 本体は右 Inspector へ移設） */
.rr-surf-icon-btn {
    width: 18px; height: 18px; padding: 0; margin-left: 2px;
    background-color: rgba(0, 0, 0, 0); border-width: 0;
    align-items: center; justify-content: center;
}
.rr-surf-icon--on   { color: var(--rr-body); }
.rr-surf-icon--dim  { color: var(--rr-muted-soft); }
.rr-surf-icon--warn { color: var(--rr-warn); }

/* Fit Mode セグメント（MASK|GRID・inset 溝 + raised 選択・UNITY-HANDOFF §5） */
.rr-seg {
    flex-direction: row;
    padding: 2px;
    margin-right: 8px;
    margin-bottom: 4px;   /* flex-wrap:wrap 時、UI Toolkit は row-gap 非対応のため折り返し行の間隔を確保 */
    background-color: var(--rr-surface-inset);
    border-width: 1px; border-color: var(--rr-hairline);
    border-radius: 5px;
}
.rr-seg__btn {
    height: 20px;
    padding: 0 10px;
    margin: 0;
    flex-direction: row;      /* dot+label を子として直接 Add する場合の中央揃え用（U6・既定の column だと
                                  縦積みになり 20px の高さから溢れて下半分が欠けて見える） */
    align-items: center;
    justify-content: center;
    border-width: 0;
    border-radius: 4px;
    background-color: var(--rr-surface-inset);   /* 溝と同色＝非選択は沈む */
    color: var(--rr-muted);
    font-size: 9px;
    letter-spacing: 0.6px;
    -unity-font-style: bold;
}
.rr-seg__btn:hover { color: var(--rr-body); }
.rr-seg__btn--active { background-color: var(--rr-surface-raised); color: var(--rr-text); }

/* SurfaceInspector（右 Inspector・U4）のヒント・Interp バッジ */
.rr-surf-hint {
    padding: 4px 8px 2px 8px;
    font-size: 11px;
    color: var(--rr-muted);
    white-space: normal;
}
.rr-surf-badge {
    font-size: 9px;
    color: var(--rr-primary);   /* Grid=歪ませる面＝primary で明示 */
    letter-spacing: 0.6px;
    -unity-font-style: bold;
}
.rr-surf-step {
    width: 18px; height: 18px;
    font-size: 12px;
    color: var(--rr-body);
    background-color: var(--rr-surface-raised);
    border-width: 1px; border-color: var(--rr-hairline-strong);
    border-radius: 3px;
    margin-left: 2px; margin-right: 2px;
    -unity-text-align: middle-center;
    padding: 0;
}
.rr-surf-step:hover { color: var(--rr-text); border-color: var(--rr-selection); }
.rr-surf-step:disabled { opacity: 0.4; }

/* ---------------------------------------------------------- Center stage */
.rr-center {
    flex-grow: 1;
    flex-direction: column;
    padding: 8px;
}

/* Preview viewport（卓の主役・OperatorUI が Final RT を rr-preview に表示） */
.rr-viewport {
    flex-grow: 1;
    background-color: var(--rr-canvas-soft);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
}
.rr-preview {
    flex-grow: 1;
    width: 100%;
    height: 100%;
}
.rr-safe-area {
    position: absolute;
    left: 5%; top: 5%; right: 5%; bottom: 5%;
    border-width: 1px;
    border-color: var(--rr-hairline);
}
.rr-corner-pin {
    position: absolute;
    width: 8px; height: 8px;
    background-color: var(--rr-selection);
}
.rr-corner-pin--tl { left: 5%;  top: 5%;    translate: -50% -50%; }
.rr-corner-pin--tr { right: 5%; top: 5%;    translate: 50% -50%; }
.rr-corner-pin--bl { left: 5%;  bottom: 5%; translate: -50% 50%; }
.rr-corner-pin--br { right: 5%; bottom: 5%; translate: 50% 50%; }
.rr-viewport-overlay-tr {
    position: absolute;
    top: 8px; right: 10px;
    flex-direction: row;
}
.rr-viewport-meta {
    position: absolute;
    bottom: 8px; left: 10px;
    color: var(--rr-muted);
    font-size: 11px;
}
/* MAPPING 中央ツールバー（EMBED⇄OUTPUT・Views・Mesh 制御・U6）。rr-viewport の外＝独立行。 */
.rr-map-toolbar {
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 8px;
}
.rr-warp-wysiwyg {
    color: var(--rr-stage-output);
    font-size: 10px;
    margin-left: 8px;
    margin-bottom: 4px;
}
/* EMBED/OUTPUT セグメントの色ドット（アクティブ=段色・非アクティブ=muted-soft） */
.rr-seg-dot { margin-right: 6px; }
.rr-seg-dot--off { background-color: var(--rr-muted-soft); }

.rr-warp-toggle {
    height: 22px;
    padding-left: 8px; padding-right: 8px;
    font-size: 10px;
    -unity-font-style: bold;
    color: var(--rr-body);
    background-color: var(--rr-surface-panel);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 4px;
    margin-right: 6px;
    margin-bottom: 4px;   /* flex-wrap:wrap 時の折り返し行の間隔（row-gap 非対応の代替） */
}
.rr-warp-toggle:hover { color: var(--rr-text); border-color: var(--rr-selection); }
.rr-warp-toggle--sub { color: var(--rr-muted); }
.rr-warp-toggle--content {
    color: var(--rr-selection);
    border-color: var(--rr-selection);
    background-color: var(--rr-canvas-soft);
}
/* GRID=細分化格子オーバーレイ ON（#34/#35・tracking ミント） */
.rr-warp-toggle--grid {
    color: var(--rr-stage-tracking);
    border-color: var(--rr-stage-tracking);
    background-color: var(--rr-canvas-soft);
}
/* TEST/CALIB ON＝テストパターンが合成/実出力に出ている（アンバーで注意喚起） */
.rr-warp-toggle--test {
    color: var(--rr-primary);
    border-color: var(--rr-primary);
    background-color: var(--rr-canvas-soft);
}
/* Grid X/Y 解像度ステッパー（§7b-A Mesh Warping・2–8） */
.rr-warp-mesh {
    flex-direction: row;
    align-items: center;
    height: 22px;
    padding-left: 6px; padding-right: 6px;
    margin-bottom: 4px;
    background-color: var(--rr-surface-panel);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 4px;
}
.rr-warp-step__lbl {
    font-size: 9px;
    -unity-font-style: bold;
    color: var(--rr-muted);
    margin-left: 4px;
    margin-right: 3px;
}
.rr-warp-step__btn {
    width: 16px; height: 16px;
    padding: 0;
    font-size: 12px;
    color: var(--rr-body);
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 3px;
    -unity-text-align: middle-center;
}
.rr-warp-step__btn:hover { border-color: var(--rr-selection); color: var(--rr-text); }
.rr-warp-step__val {
    font-size: 11px;
    color: var(--rr-text);
    min-width: 14px;
    margin-left: 3px; margin-right: 3px;
    -unity-text-align: middle-center;
}
/* BEZIER ⇄ Linear 補間トグル（§7b-A）。ON=selection 青（滑らか面が有効） */
.rr-warp-step__bezier {
    height: 16px;
    margin-left: 8px;
    padding-left: 6px; padding-right: 6px;
    font-size: 9px;
    -unity-font-style: bold;
    letter-spacing: 0.6px;
    color: var(--rr-muted);
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 3px;
}
.rr-warp-step__bezier:hover { border-color: var(--rr-selection); }
.rr-warp-step__bezier--on {
    color: var(--rr-selection);
    border-color: var(--rr-selection);
    background-color: var(--rr-canvas-soft);
}

/* Mapping（TRACK=Input/Output 分割・OUTPUT=単一 warp）— warp のドラッグ/メッシュ線は #21 */
.rr-map-col { flex-grow: 1; flex-direction: column; }
.rr-map-row { flex-grow: 1; flex-direction: row; }
.rr-map-pane {
    flex-grow: 1;
    background-color: var(--rr-canvas-soft);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
}
.rr-map-pane--gap-left { margin-left: 8px; }
.rr-video-fill {
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    background-color: var(--rr-surface-inset);
    overflow: hidden;
}
.rr-video-fill__bars {
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    flex-direction: row;
    opacity: 0.16;
}
.rr-video-fill__bar { flex-grow: 1; }
/* バーの色はクラスで指定（inline style の var() は UI Toolkit 非対応＝NRE のため） */
.rr-video-fill__bar--source   { background-color: var(--rr-stage-source); }
.rr-video-fill__bar--output   { background-color: var(--rr-stage-output); }
.rr-video-fill__bar--tracking { background-color: var(--rr-stage-tracking); }
.rr-video-fill__bar--audio    { background-color: var(--rr-stage-audio); }
.rr-video-fill__bar--effects  { background-color: var(--rr-stage-effects); }
.rr-video-fill__bar--scene    { background-color: var(--rr-stage-scene); }
.rr-video-fill__bar--text     { background-color: var(--rr-text); }
/* 中央を落として映像信号らしく見せる（radial-gradient 非対応の近似） */
.rr-video-fill__vignette {
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    background-color: rgba(18, 16, 9, 0.45);
}
.rr-video-fill__label-row {
    position: absolute;
    top: 8px; left: 8px;
    flex-direction: row;
    align-items: center;
}
.rr-video-fill__dot {
    width: 7px; height: 7px;
    border-radius: 9999px;
    margin-right: 6px;
}
.rr-video-fill__label {
    color: var(--rr-body);
    font-size: 10px;
    -unity-font-style: bold;
}
.rr-warp-pin {
    position: absolute;
    width: 8px; height: 8px;
    background-color: var(--rr-selection);
    border-width: 1px;
    border-color: var(--rr-canvas);
    translate: -50% -50%;
}
.rr-warp-pin--selected {
    width: 12px; height: 12px;
    background-color: var(--rr-primary);
    border-color: var(--rr-primary);
}
.rr-map-hint {
    height: 24px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    margin-top: 8px;
}
.rr-map-hint__text { color: var(--rr-muted); font-size: 11px; }

/* ---------------------------------------------------------- Right dock (inspector) */
.rr-inspector-title-row {
    height: 26px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-left: 2px;
    padding-right: 2px;
    margin-top: 8px;
    margin-bottom: 2px;
}
#rr-inspector-title {
    color: var(--rr-muted);
    font-size: 11px;
    -unity-font-style: bold;
}
.rr-inspector { flex-grow: 1; }

/* Inspector の静的行（Row/Field・#22 でバインド） */
.rr-insp-row {
    height: 28px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-left: 8px;
    padding-right: 8px;
}
.rr-field {
    color: var(--rr-body);
    font-size: 12px;
    -unity-font-style: bold;
}

/* Buttons（primary/secondary/ghost・sm） */
.rr-btn-row { flex-direction: row; margin-top: 10px; padding-left: 8px; }
.rr-btn {
    height: 24px;
    padding-left: 12px;
    padding-right: 12px;
    border-radius: 4px;
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    margin-right: 6px;
    border-width: 1px;
}
.rr-btn--primary {
    background-color: var(--rr-primary);
    color: var(--rr-on-primary);
    border-color: var(--rr-primary);
}
.rr-btn--secondary {
    background-color: var(--rr-surface-raised);
    color: var(--rr-text);
    border-color: var(--rr-hairline-strong);
}
.rr-btn--ghost {
    background-color: rgba(0, 0, 0, 0);
    color: var(--rr-body);
    border-color: var(--rr-hairline-strong);
}

/* ---------------------------------------------------------- Timeline (bottom dock) */
.rr-timeline {
    height: 208px;   /* タブバー(30px) 追加分を拡張 */
    flex-shrink: 0;
    flex-direction: column;
    background-color: var(--rr-surface-panel);
    border-top-width: 1px;
    border-top-color: var(--rr-hairline-strong);
}

/* タブバー（song/short バンク・ブラウザ風・07b §3.5.2） */
.rr-tl-tabs {
    height: 36px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: flex-end;
    padding-left: 8px;
    padding-right: 8px;
    background-color: var(--rr-canvas);
    border-bottom-width: 1px;
    border-bottom-color: var(--rr-hairline-strong);
}
.rr-tl-tab {
    height: 32px;
    flex-direction: row;
    align-items: center;
    padding-left: 10px;
    padding-right: 8px;
    background-color: var(--rr-canvas);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-top-width: 2px;
    border-top-color: rgba(0, 0, 0, 0);
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    margin-right: 2px;
    margin-bottom: -1px;
}
.rr-tl-tab:hover { background-color: var(--rr-surface-raised); }
.rr-tl-tab--active {
    background-color: var(--rr-surface-panel);
    border-bottom-color: var(--rr-surface-panel);
}
.rr-tl-tab--seq.rr-tl-tab--active   { border-top-color: var(--rr-live); }
.rr-tl-tab--short.rr-tl-tab--active { border-top-color: var(--rr-primary); }
.rr-tl-tab--songlist.rr-tl-tab--active { border-top-color: var(--rr-selection); }
.rr-tl-tab__dot {
    width: 6px; height: 6px;
    border-radius: 9999px;
    margin-right: 7px;
    opacity: 0.55;
}
.rr-tl-tab--seq .rr-tl-tab__dot      { background-color: var(--rr-live); }
.rr-tl-tab--short .rr-tl-tab__dot    { background-color: var(--rr-primary); }
.rr-tl-tab--songlist .rr-tl-tab__dot { background-color: var(--rr-selection); }
.rr-tl-tab--active .rr-tl-tab__dot { opacity: 1; }
.rr-tl-tab__name { color: var(--rr-muted); font-size: 12px; -unity-font-style: bold; }
.rr-tl-tab--active .rr-tl-tab__name { color: var(--rr-text); }
.rr-tl-add {
    width: 22px; height: 22px;
    margin-left: 4px;
    margin-bottom: 2px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 4px;
    color: var(--rr-body);
    font-size: 13px;
    -unity-text-align: middle-center;
    padding: 0;
}
.rr-tl-add:hover { background-color: var(--rr-surface-raised); }
.rr-tl-add:disabled { opacity: 0.4; }
/* 動的タブバー（07-10 App.jsx）：タブ生成コンテナ・kind アイコン・閉じる・追加メニュー。
   タブ多数時は横スクロール（U10・07-14）：ScrollView(mode=Horizontal)・スクロールバー非表示は UXML 属性。 */
.rr-tl-tablist { flex-direction: row; align-items: flex-end; flex-shrink: 1; }
.rr-tl-tablist > .unity-scroll-view__content-viewport { flex-direction: row; align-items: flex-end; }
/* keycap 型チップ（07-10）: 物理キー風＝inset 背景＋下辺 2px。glyph 大＋pad 番号小。 */
.rr-keycap {
    flex-direction: row;
    align-items: center;
    margin-left: 7px;
    padding: 1px 6px;
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-bottom-width: 2px;
    border-radius: 3px;
}
.rr-keycap__glyph { font-size: 11px; color: var(--rr-body); }
.rr-keycap__idx { font-size: 8px; color: var(--rr-muted); margin-left: 3px; }
.rr-keycap--active .rr-keycap__glyph { color: var(--rr-primary); }
.rr-keycap--empty {
    background-color: rgba(0, 0, 0, 0);
    border-color: var(--rr-hairline);
    border-bottom-width: 1px;
}
.rr-keycap--empty .rr-keycap__glyph { color: var(--rr-muted-soft); }
.rr-tl-tab__icon { width: 13px; height: 13px; margin-right: 7px; color: var(--rr-muted); }
.rr-tl-tab--active.rr-tl-tab--seq .rr-tl-tab__icon      { color: var(--rr-live); }
.rr-tl-tab--active.rr-tl-tab--short .rr-tl-tab__icon    { color: var(--rr-primary); }
.rr-tl-tab--active.rr-tl-tab--songlist .rr-tl-tab__icon { color: var(--rr-selection); }
.rr-tl-tab__close {
    width: 15px; height: 15px;
    margin-left: 4px;
    padding: 0;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-radius: 3px;
    color: var(--rr-muted);
    font-size: 13px;
    -unity-text-align: middle-center;
}
.rr-tl-tab__close:hover { background-color: var(--rr-surface-inset); color: var(--rr-text); }
.rr-tl-addwrap { position: relative; flex-direction: row; align-items: flex-end; }
.rr-tl-addmenu {
    position: absolute;
    top: 26px; left: 0;
    flex-direction: column;
    min-width: 128px;
    background-color: var(--rr-surface-panel);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 6px;
    padding: 4px;
}

/* head の time / gate 表示グループ（song=time・short=GATE hold-fire） */
.rr-tl-head-group { flex-direction: row; align-items: center; }
.rr-tl-gate {
    color: var(--rr-primary);
    font-size: 11px;
    -unity-font-style: bold;
    margin-left: 8px;
}
.rr-tl-gate-sub { color: var(--rr-muted); font-size: 11px; margin-left: 6px; }

/* SHORT ボディ（キー割当行＋ホールド発火レーン） */
.rr-tl-short { flex-grow: 1; flex-direction: column; }
.rr-tl-keyrow {
    height: 30px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    border-bottom-width: 1px;
    border-bottom-color: var(--rr-hairline);
}
.rr-tl-keyrow__label {
    color: var(--rr-muted);
    font-size: 10px;
    -unity-font-style: bold;
    margin-right: 10px;
}
.rr-tl-keyrow__hint { color: var(--rr-muted-soft); font-size: 10px; margin-left: 10px; }
.rr-short-pad {
    height: 24px;
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 1px;
    border-color: var(--rr-primary);
    border-radius: 5px;
    color: var(--rr-primary);
    font-size: 12px;
}
.rr-short-pad:disabled { opacity: 0.7; }
/* 割当ボタンの中身（⌨ アイコン＋キー文字＋⌄）。色は継承 color（primary）で追従・U7。 */
.rr-short-pad__icon { width: 13px; height: 13px; margin-right: 6px; }
.rr-short-pad__glyph { font-size: 12px; color: var(--rr-primary); }
.rr-short-pad__caret { font-size: 12px; color: var(--rr-primary); margin-left: 6px; opacity: 0.7; }
/* 未割当は減光（グリフ＝muted・アイコン/枠は継承）。 */
.rr-short-pad--unassigned { border-color: var(--rr-hairline-strong); color: var(--rr-muted); }
.rr-short-pad--unassigned .rr-short-pad__glyph { color: var(--rr-muted); }
.rr-short-pad--unassigned .rr-short-pad__caret { color: var(--rr-muted); }
/* Short の追加表示レーン置き場（U7・揮発） */
.rr-short-lanes { flex-direction: column; }
.rr-short-holdloop { margin-left: 12px; font-size: 11px; color: var(--rr-muted); }
/* 4×4 パッド割当マトリクス（§7・#13）。見た目の詰めは UI Builder で。 */
.rr-pad-matrix {
    position: absolute;
    left: 92px;   /* Key 行左端の +Track ＋ divider の分だけ右へ（割当ボタン直下・U7） */
    top: 28px;
    flex-direction: column;
    background-color: var(--rr-surface-raised);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 6px;
    padding: 6px;
}
.rr-pad-matrix__row { flex-direction: row; }
.rr-pad-cell {
    width: 34px; height: 28px;
    margin: 2px;
    align-items: center;
    justify-content: center;
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 4px;
    color: var(--rr-muted);
    font-size: 10px;
    padding: 0;
}
.rr-pad-cell:hover { border-color: var(--rr-selection); }
.rr-pad-cell--mine {
    background-color: var(--rr-primary);
    border-color: var(--rr-primary);
    color: var(--rr-on-primary);
}
.rr-pad-cell--used { border-color: var(--rr-stage-scene); color: var(--rr-stage-scene); }
/* マトリクスの割当キー表示（グリフ大＋pad 番号小・07-10 KEY 割当）。 */
.rr-pad-matrix__head {
    font-size: 9px;
    -unity-font-style: bold;
    letter-spacing: 0.8px;
    color: var(--rr-muted);
    margin-bottom: 6px;
    margin-left: 2px;
}
.rr-pad-cell__glyph { font-size: 13px; color: var(--rr-body); }
.rr-pad-cell--mine .rr-pad-cell__glyph { color: var(--rr-on-primary); }
.rr-pad-cell--used .rr-pad-cell__glyph { color: var(--rr-muted-soft); }
.rr-pad-cell__idx {
    position: absolute;
    bottom: 2px; right: 3px;
    font-size: 7px;
    color: var(--rr-muted-soft);
}
.rr-pad-cell--mine .rr-pad-cell__idx { color: var(--rr-on-primary); }
/* 割当ボタン未割当時（琥珀→減光）。 */
.rr-short-pad--unassigned {
    border-color: var(--rr-hairline-strong);
    color: var(--rr-muted);
}
.rr-short-lane { height: 40px; }
.rr-short-hold {
    width: 24px; height: 24px;
    align-items: center;
    justify-content: center;
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 5px;
    color: var(--rr-muted);
    padding: 0;
    margin-right: 6px;
}
.rr-short-hold:hover { border-color: var(--rr-primary); }
.rr-short-hold--held {
    background-color: var(--rr-primary);
    border-color: var(--rr-primary);
    color: var(--rr-on-primary);
}
/* Short 発火中のレーン点灯（Live Amber・§7 #8・07-09）。発火は割当パッド/キー経由。 */
.rr-short-clip--held {
    border-color: var(--rr-primary);
    background-color: var(--rr-primary);
}
.rr-short-clip--held .rr-clip__label { color: var(--rr-on-primary); }
.rr-timeline-head {
    height: 30px;
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    border-bottom-width: 1px;
    border-bottom-color: var(--rr-hairline);
}
.rr-timeline-title {
    color: var(--rr-muted);
    font-size: 10px;
    -unity-font-style: bold;
}
.rr-timeline-time { color: var(--rr-text); font-size: 15px; margin-left: 4px; }
.rr-timeline-total { color: var(--rr-muted); font-size: 11px; margin-left: 6px; }
.rr-timeline-body { flex-grow: 1; }

/* トラック行のみ縦スクロール（ルーラー/再生ヘッドは固定・07-13）。スクロールバーは非表示（UXML 属性）。 */
.rr-tl-tracklist { flex-grow: 1; }
.rr-tl-tracklist > .unity-scroll-view__content-viewport { flex-grow: 1; }

.rr-ruler {
    height: 18px;
    margin-left: 96px;
    border-bottom-width: 1px;
    border-bottom-color: var(--rr-hairline);
    flex-direction: row;
}
.rr-ruler-mark {
    color: var(--rr-muted);
    font-size: 10px;
    width: 90px;
    -unity-text-align: middle-left;
    padding-left: 5px;
    border-left-width: 1px;
    border-left-color: var(--rr-hairline-strong);
}

.rr-track {
    height: 34px;
    flex-direction: row;
    border-bottom-width: 1px;
    border-bottom-color: var(--rr-hairline-soft);
}
.rr-track-head {
    width: 96px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    border-right-width: 1px;
    border-right-color: var(--rr-hairline);
}
.rr-track-name { color: var(--rr-text); font-size: 11px; margin-left: 6px; }
.rr-track-name--off { color: var(--rr-muted); }
.rr-track-lane { flex-grow: 1; }
.rr-track-tail {
    width: 74px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    padding-left: 8px;
    padding-right: 8px;
    border-left-width: 1px;
    border-left-color: var(--rr-hairline);
}
.rr-track-tail__label { color: var(--rr-muted); font-size: 9px; }

.rr-clip {
    position: absolute;
    top: 4px; bottom: 4px;
    border-width: 1px;
    border-radius: 3px;
    overflow: hidden;
    justify-content: center;
    padding-left: 7px;
    background-color: var(--rr-surface-inset);
}
.rr-clip__label {
    color: var(--rr-text);
    font-size: 10px;
    -unity-font-style: bold;
}
.rr-clip--source { border-color: var(--rr-stage-source); }
.rr-clip--fx     { border-color: var(--rr-stage-effects); }
.rr-clip--audio  { border-color: var(--rr-stage-audio); }

.rr-playhead {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background-color: var(--rr-selection);
}

/* ---------------------------------------------------------- Bottom bar: mode + page tabs */
.rr-bottom-bar {
    height: 44px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    background-color: var(--rr-canvas);
    border-top-width: 1px;
    border-top-color: var(--rr-hairline-strong);
    padding-left: 10px;
    padding-right: 10px;
}
.rr-mode-switch {
    flex-direction: row;
    align-items: center;
    padding: 3px;
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 6px;
}
.rr-mode-opt {
    height: 26px;
    flex-direction: row;
    align-items: center;
    padding-left: 12px;
    padding-right: 12px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-radius: 4px;
    color: var(--rr-muted);
    font-size: 11px;
    -unity-font-style: bold;
    margin-right: 2px;
}
.rr-mode-opt__dot {
    width: 6px; height: 6px;
    border-radius: 9999px;
    background-color: var(--rr-muted-soft);
    margin-right: 6px;
}
.rr-mode-opt--active { background-color: var(--rr-surface-raised); color: var(--rr-text); }
.rr-mode-opt--active .rr-mode-opt__dot { background-color: var(--rr-live); }
.rr-mode-opt--live-active { background-color: var(--rr-primary); color: var(--rr-on-primary); }
.rr-mode-opt--live-active .rr-mode-opt__dot { background-color: var(--rr-on-primary); }

/* Page tabs（下部・DaVinci のページ相当） */
.rr-page-tabs {
    height: 36px;
    flex-direction: row;
    align-items: stretch;
}
.rr-page-tab {
    padding-left: 18px;
    padding-right: 18px;
    -unity-text-align: middle-center;
    color: var(--rr-muted);
    font-size: 11px;
    -unity-font-style: bold;
    background-color: rgba(0, 0, 0, 0);
    border-top-width: 2px;
    border-top-color: rgba(0, 0, 0, 0);
}
.rr-page-tab--active { color: var(--rr-text); background-color: var(--rr-canvas-soft); }
.rr-page-tab--active.rr-stage-source   { border-top-color: var(--rr-stage-source); }
.rr-page-tab--active.rr-stage-tracking { border-top-color: var(--rr-stage-tracking); }
.rr-page-tab--active.rr-stage-effects  { border-top-color: var(--rr-stage-effects); }
.rr-page-tab--active.rr-stage-audio    { border-top-color: var(--rr-stage-audio); }
.rr-page-tab--active.rr-stage-output   { border-top-color: var(--rr-stage-output); }
.rr-page-tab--active.rr-stage-scene    { border-top-color: var(--rr-stage-scene); }

.rr-perf { color: var(--rr-muted); font-size: 11px; }

/* ============================================================ FX chain list（左ドック・OperatorUI 駆動） */
.rr-fx-list {
    flex-grow: 0;
    flex-direction: column;
}
.rr-fx-item {
    height: 28px;
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    border-left-width: 2px;
    border-left-color: var(--rr-stage-effects); /* FX 段アクセント */
    border-radius: 2px;
}
.rr-fx-item:hover { background-color: var(--rr-surface-raised); }
.rr-fx-item--selected {
    background-color: var(--rr-surface-raised);
    border-left-color: var(--rr-selection);
}
.rr-fx-name {
    flex-grow: 1;
    margin-left: 6px;
    color: var(--rr-body);
}
.rr-fx-item--selected .rr-fx-name { color: var(--rr-primary); -unity-font-style: bold; }
.rr-fx-name--disabled { color: var(--rr-muted-soft); }

/* ============================================================ Parameter rows (inspector・OperatorUI 駆動) */
.rr-param-row {
    height: 28px;
    flex-direction: row;
    align-items: center;
    border-radius: 2px;
    border-left-width: 2px;
    border-left-color: rgba(0, 0, 0, 0);
    padding-left: 6px;
    padding-right: 4px;
}
.rr-param-row:hover { background-color: var(--rr-surface-raised); }
.rr-param-row--selected {
    background-color: var(--rr-surface-raised);
    border-left-color: var(--rr-selection);
}
.rr-param-label {
    width: 92px;
    color: var(--rr-body);
    font-size: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
}
.rr-param-slider {
    flex-grow: 1;
    margin-left: 4px;
    margin-right: 8px;
}
.rr-param-midi {
    color: var(--rr-muted);
    font-size: 10px;
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 9999px;
    padding: 1px 6px;
    margin-right: 6px;
}
.rr-param-value {
    min-width: 48px;
    color: var(--rr-text);
    -unity-text-align: middle-right;
    font-size: 12px;
}
.rr-param-value--armed { color: var(--rr-primary); }

/* Slider 溝/つまみ（DESIGN: 溝 inset・つまみ text） */
.rr-param-slider .unity-base-slider__tracker {
    background-color: var(--rr-surface-inset);
    border-color: var(--rr-hairline-soft);
}
.rr-param-slider .unity-base-slider__dragger {
    background-color: var(--rr-text);
    border-radius: 4px;
    width: 10px;
    height: 10px;
}

/* Toggle: OFF inset / ON live */
.rr-fx-toggle .unity-toggle__checkmark {
    background-color: var(--rr-surface-inset);
    border-color: var(--rr-hairline);
    border-radius: 2px;
    width: 16px;
    height: 16px;
}
.rr-fx-toggle:checked .unity-toggle__checkmark {
    background-color: var(--rr-live);
    border-color: var(--rr-live);
}

/* ============================================================ StagePill（署名・6段の状態表示専用） */
.rr-stage-pill {
    color: var(--rr-canvas);
    font-size: 11px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    padding: 3px 8px;
    border-radius: 9999px;
}
.rr-stage-pill--source   { background-color: var(--rr-stage-source); }
.rr-stage-pill--tracking { background-color: var(--rr-stage-tracking); }
.rr-stage-pill--effects  { background-color: var(--rr-stage-effects); }
.rr-stage-pill--audio    { background-color: var(--rr-stage-audio); }
.rr-stage-pill--output   { background-color: var(--rr-stage-output); }
.rr-stage-pill--scene    { background-color: var(--rr-stage-scene); }

/* ============================================================ Badges / status pills */
.rr-badge {
    color: var(--rr-muted);
    background-color: var(--rr-surface-raised);
    font-size: 11px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    padding: 2px 8px;
    margin-left: 6px;
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 9999px;
}
.rr-badge--live      { background-color: rgba(0, 0, 0, 0); color: var(--rr-live);      border-color: var(--rr-live); }
.rr-badge--record    { background-color: rgba(0, 0, 0, 0); color: var(--rr-record);    border-color: var(--rr-record); }
.rr-badge--warn      { background-color: rgba(0, 0, 0, 0); color: var(--rr-warn);      border-color: var(--rr-warn); }
.rr-badge--selection { background-color: rgba(0, 0, 0, 0); color: var(--rr-selection); border-color: var(--rr-selection); }
.rr-badge--on { color: var(--rr-on-primary); background-color: var(--rr-live); }

/* ============================================================ 出力ルート（上バー OUTPUT メニュー＋要約） */
.rr-output {
    flex-direction: row;
    align-items: center;
}
.rr-output-btn {
    height: 24px;
    padding-left: 4px;
    padding-right: 4px;
    background-color: rgba(0, 0, 0, 0);
    color: var(--rr-body);
    border-width: 0;
    font-size: 11px;
    -unity-font-style: bold;
}
.rr-output-btn:hover { color: var(--rr-text); }
/* OUTPUT 見出し（body 色・ラベルのみ・§2） */
.rr-output-head {
    color: var(--rr-body);
    font-size: 11px;
    -unity-font-style: bold;
    margin-right: 2px;
}
/* 出力ルートの状態トグル（Full/Syphon/NDI・ラベルのみ・ON=緑／OFF=灰・クリックで切替・§2） */
.rr-out-chip {
    height: 20px;
    margin-left: 8px;
    padding-left: 0;
    padding-right: 0;
    border-width: 0;
    font-size: 11px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    background-color: rgba(0, 0, 0, 0);
}
.rr-out-chip--on  { color: var(--rr-live); }
.rr-out-chip--off { color: var(--rr-muted); }
.rr-out-chip:disabled { opacity: 0.4; }

/* 本番 Live 中の出力ルート確認ポップオーバー（誤配信防止・U5・§2） */
.rr-route-confirm {
    position: absolute;
    flex-direction: column;
    min-width: 168px;
    background-color: var(--rr-surface-panel);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 6px;
    padding: 10px;
}
.rr-route-confirm-row { flex-direction: row; align-items: center; margin-bottom: 8px; }
.rr-route-confirm-dot { width: 7px; height: 7px; border-radius: 9999px; margin-right: 8px; flex-shrink: 0; }
.rr-route-confirm-dot--on  { background-color: var(--rr-live); }
.rr-route-confirm-dot--off { background-color: var(--rr-muted-soft); }
.rr-route-confirm-text { color: var(--rr-text); font-size: 12px; }

.rr-hint {
    color: var(--rr-muted-soft);
    font-size: 11px;
    margin-top: 6px;
    white-space: normal;
}

/* ---------------------------------------------------------- 終了 UX（§7・#12）。詰めは UI Builder で */
.rr-brand-group { flex-direction: row; align-items: center; }
.rr-brand-menu {
    position: absolute;
    left: 12px;
    top: 44px;
    flex-direction: column;
    background-color: var(--rr-surface-panel);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 6px;
    padding: 4px;
    min-width: 180px;
}
.rr-menu-item {
    height: 26px;
    -unity-text-align: middle-left;
    padding-left: 8px;
    padding-right: 8px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-left-width: 2px;
    border-left-color: rgba(0, 0, 0, 0);
    color: var(--rr-text);
    font-size: 12px;
}
.rr-menu-item:hover { background-color: var(--rr-surface-raised); }
.rr-menu-item:disabled { color: var(--rr-muted-soft); }
/* タイムラインの New Sequence/Short/Song（07-12・§7c で3種へ改名＝U11）: 種別を左境界色で即判別。 */
.rr-menu-item--seq      { border-left-color: var(--rr-live); }
.rr-menu-item--short    { border-left-color: var(--rr-primary); }
.rr-menu-item--songlist { border-left-color: var(--rr-selection); }

.rr-modal-overlay {
    position: absolute;
    left: 0; top: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.6);
    align-items: center;
    justify-content: center;
}
.rr-modal {
    min-width: 320px;
    background-color: var(--rr-surface-panel);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 8px;
    padding: 18px;
}
.rr-modal__title { color: var(--rr-text); font-size: 15px; -unity-font-style: bold; }
.rr-modal__msg { color: var(--rr-muted); font-size: 12px; margin-top: 8px; white-space: normal; }
.rr-modal__actions { flex-direction: row; justify-content: flex-end; margin-top: 16px; }
.rr-modal-btn {
    height: 30px;
    padding-left: 14px;
    padding-right: 14px;
    margin-left: 8px;
    background-color: var(--rr-surface-raised);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 5px;
    color: var(--rr-text);
    font-size: 12px;
}
.rr-modal-btn--primary {
    background-color: var(--rr-primary);
    border-color: var(--rr-primary);
    color: var(--rr-on-primary);
}
.rr-modal-btn--danger {
    background-color: var(--rr-record);
    border-color: var(--rr-record);
    color: var(--rr-text);
}
.rr-quit-onair { flex-direction: row; align-items: center; margin-bottom: 10px; }
.rr-quit-onair__badge {
    background-color: var(--rr-record);
    color: var(--rr-text);
    font-size: 10px;
    -unity-font-style: bold;
    padding-left: 6px; padding-right: 6px;
    padding-top: 2px; padding-bottom: 2px;
    border-radius: 3px;
}
.rr-quit-onair__routes { color: var(--rr-record); font-size: 11px; margin-left: 8px; }

/* ============================================================ per-kind Inspector（U2） */
/* オーディオ帯域メーター（audio-input・毎フレーム高さ更新は OperatorUI 側） */
.rr-meter-row {
    flex-direction: row;
    align-items: flex-end;
    height: 64px;
    padding: 6px 2px 10px;
}
.rr-meter {
    width: 16px;
    height: 100%;
    margin-right: 8px;
    background-color: var(--rr-surface-inset);
    border-radius: 2px;
    justify-content: flex-end;
    overflow: hidden;
}
.rr-meter__fill { width: 100%; background-color: var(--rr-stage-audio); }

/* OSC アドレス表示（fx・CodeSurface 相当の簡易版） */
.rr-code-row { margin-top: 8px; padding-left: 6px; padding-right: 6px; }
.rr-code-label {
    font-size: 10px;
    -unity-font-style: bold;
    letter-spacing: 0.6px;
    color: var(--rr-muted);
    margin-bottom: 3px;
}
.rr-code-box {
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 4px;
    padding: 6px 8px;
}
.rr-code-text { color: var(--rr-text); font-size: 11px; }

/* ============================================================ Timeline track（U3・動的行） */
/* 選択行 = surface-raised 背景 + 左 2px selection（§3）。base の左境界を透明で確保しレイアウトを保つ。 */
.rr-track-head {
    border-left-width: 2px;
    border-left-color: rgba(0, 0, 0, 0);
}
.rr-track-head--selected {
    background-color: var(--rr-surface-raised);
    border-left-color: var(--rr-selection);
}
.rr-track-head:hover { background-color: var(--rr-surface-raised); }

/* + TRACK ボタン（transport 左端・ghost+hairline・uppercase・§7） */
.rr-addtrack-wrap { position: relative; flex-direction: row; align-items: center; }
.rr-add-track {
    height: 22px;
    padding-left: 8px;
    padding-right: 8px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
    border-radius: 4px;
    color: var(--rr-body);
    font-size: 10px;
    -unity-font-style: bold;
    letter-spacing: 0.6px;
}
.rr-add-track:hover { background-color: var(--rr-surface-raised); }

/* + TRACK popover: VIDEO/AUDIO グループ見出し＋ファイル行（rr-tl-addmenu を土台に再利用）。 */
.rr-addtrack-group {
    flex-direction: row;
    align-items: center;
    padding: 5px 8px 2px;
}
.rr-addtrack-group__dot { width: 6px; height: 6px; border-radius: 9999px; margin-right: 6px; }
.rr-addtrack-group__label {
    font-size: 9px;
    -unity-font-style: bold;
    letter-spacing: 0.8px;
    color: var(--rr-muted);
}
.rr-addtrack-file {
    flex-direction: row;
    align-items: center;
    height: 26px;
    padding-left: 8px;
    padding-right: 8px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    color: var(--rr-text);
}
.rr-addtrack-file:hover { background-color: var(--rr-surface-raised); }
.rr-addtrack-file__name {
    flex-grow: 1;
    font-size: 11px;
    color: var(--rr-text);
    overflow: hidden;
    text-overflow: ellipsis;
}
.rr-addtrack-file__dur { font-size: 10px; color: var(--rr-muted); }

/* PERFORM 左ドック Banks（保存済み Sequence/Short/Song 一覧・U10・07-14）。
   クリックでタイムラインの該当タブを開く（Inspector 選択にはしない・rr-list-item を流用）。 */
.rr-list-dot--seq      { background-color: var(--rr-live); }
.rr-list-dot--short    { background-color: var(--rr-primary); }
.rr-list-dot--songlist { background-color: var(--rr-selection); }

/* Song（Sequence セットリスト）本文＝MPC 流 横ストリップ：集計ヘッダー＋左固定 Add Sequence レール＋
   横スクロールのステップカード列（§7c・07-18・U12。旧2ペインを全面刷新）。 */
.rr-tl-songlist { flex-direction: column; flex-grow: 1; min-height: 0; }

/* ヘッダー：PLAY ORDER 集計＋選択 Sequence へジャンプ */
.rr-song-head {
    height: 26px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    padding-left: 10px;
    padding-right: 10px;
    border-bottom-width: 1px;
    border-bottom-color: var(--rr-hairline);
}
.rr-song-head__label {
    font-size: 10px;
    -unity-font-style: bold;
    letter-spacing: 0.8px;
    color: var(--rr-muted);
    margin-right: 8px;
}
.rr-song-head__summary { font-size: 10px; color: var(--rr-muted); }

/* 本文：左固定レール＋横スクロールのカード列 */
.rr-song-body {
    flex-grow: 1;
    min-height: 0;
    flex-direction: row;
    padding: 10px;
}

/* Add Sequence レール（左端固定・全 Sequence 常時一覧・1クリックで末尾追加） */
.rr-song-rail {
    width: 158px;
    flex-shrink: 0;
    flex-direction: column;
    min-height: 0;
    margin-right: 8px;
    border-width: 1px;
    border-color: var(--rr-hairline-strong);  /* UI Toolkit は破線非対応のため実線ヘアラインで代替 */
    border-radius: 6px;
}
.rr-song-rail__label {
    padding: 7px 10px 4px 10px;
    font-size: 10px;
    -unity-font-style: bold;
    letter-spacing: 0.7px;
    color: var(--rr-muted);
    flex-shrink: 0;
}
/* レール一覧（ScrollView）：viewport 側にも flex-grow を明示（自身の flex-grow だけでは高さ非伝播・既知の罠）。 */
.rr-song-rail__list { flex-grow: 1; min-height: 0; }
.rr-song-rail__list > .unity-scroll-view__content-viewport { flex-grow: 1; }
.rr-song-rail-item {
    height: 26px;
    flex-direction: row;
    align-items: center;
    padding-left: 7px;
    padding-right: 7px;
    border-radius: 4px;
}
.rr-song-rail-item:hover { background-color: var(--rr-surface-raised); }
.rr-song-rail-item__dot {
    width: 6px; height: 6px;
    flex-shrink: 0;
    margin-right: 7px;
    border-radius: 3px;
    background-color: var(--rr-semantic-live);
}
.rr-song-rail-item__name {
    flex-grow: 1;
    font-size: 12px;
    color: var(--rr-text);
    overflow: hidden;
    text-overflow: ellipsis;
}
.rr-song-rail-item__plus { width: 12px; height: 12px; flex-shrink: 0; color: var(--rr-muted); }
.rr-song-rail__empty {
    padding: 2px 7px;
    font-size: 11px;
    color: var(--rr-muted);
    white-space: normal;
}

/* ステップカード列（横スクロール・.rr-tl-tablist と同じ横方向の罠対策）。 */
.rr-song-strip { flex-grow: 1; min-width: 0; flex-direction: row; }
.rr-song-strip > .unity-scroll-view__content-viewport { flex-direction: row; }
.rr-song-strip__empty {
    -unity-text-align: middle-left;
    white-space: normal;
    font-size: 12px;
    color: var(--rr-muted);
}

/* ステップカード（幅158px・上段=番号/名前/pen/×・下段=×N ステッパー＋並べ替え）。 */
.rr-song-card {
    width: 158px;
    flex-shrink: 0;
    margin-right: 8px;
    flex-direction: column;
    justify-content: space-between;
    padding: 8px 10px;
    border-radius: 6px;
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline-strong);
}
.rr-song-card:hover { background-color: var(--rr-surface-raised); }
.rr-song-card--active {
    background-color: var(--rr-surface-raised);
    border-color: var(--rr-selection);
}
/* 再生中カード（#27b・CurrentSongStep 追随）。選択枠(selection)とは独立の状態＝live 色で区別。 */
.rr-song-card--playing { border-color: var(--rr-semantic-live); }
.rr-song-card--playing .rr-song-card__idx { color: var(--rr-semantic-live); }
.rr-song-card__top { flex-direction: row; align-items: center; margin-bottom: 6px; }
.rr-song-card__idx { font-size: 10px; color: var(--rr-muted); margin-right: 6px; flex-shrink: 0; }
.rr-song-card--active .rr-song-card__idx { color: var(--rr-selection); }
.rr-song-card__name {
    flex-grow: 1;
    font-size: 12px;
    -unity-font-style: bold;
    color: var(--rr-text);
    overflow: hidden;
    text-overflow: ellipsis;
    margin-right: 4px;
}
.rr-song-card__iconbtn {
    width: 18px; height: 18px;
    flex-shrink: 0;
    padding: 0;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    -unity-text-align: middle-center;
    font-size: 13px;
    color: var(--rr-muted-soft);
}
.rr-song-card__pen { width: 12px; height: 12px; flex-shrink: 0; color: var(--rr-muted-soft); }
.rr-song-card:hover .rr-song-card__pen { color: var(--rr-selection); }
.rr-song-card--active .rr-song-card__pen { color: var(--rr-selection); }
.rr-song-card__del { color: var(--rr-muted-soft); }
.rr-song-card:hover .rr-song-card__del { color: var(--rr-semantic-record); }
.rr-song-card--active .rr-song-card__del { color: var(--rr-semantic-record); }
.rr-song-card__bottom { flex-direction: row; align-items: center; }
.rr-song-card__stepbtn {
    width: 22px; height: 22px;
    flex-shrink: 0;
    padding: 0;
    background-color: var(--rr-surface-inset);
    border-width: 1px;
    border-color: var(--rr-hairline);
    border-radius: 4px;
    color: var(--rr-body);
    font-size: 12px;
    -unity-text-align: middle-center;
}
.rr-song-card__stepbtn:hover { background-color: var(--rr-surface-raised); }
.rr-song-card__stepbtn--disabled { opacity: 0.3; }
.rr-song-card__repeat {
    flex-grow: 1;
    -unity-text-align: middle-center;
    font-size: 13px;
    color: var(--rr-text);
}
.rr-song-card__divider {
    width: 1px; height: 14px;
    flex-shrink: 0;
    margin-left: 2px; margin-right: 2px;
    background-color: var(--rr-hairline);
}

/* カード間の再生フロー矢印。 */
.rr-song-arrow {
    flex-shrink: 0;
    align-self: center;
    margin-right: 8px;
    font-size: 12px;
    color: var(--rr-muted-soft);
    -unity-text-align: middle-center;
}
