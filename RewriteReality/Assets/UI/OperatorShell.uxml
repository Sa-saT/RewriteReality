                            <ui:Label text="OVERLAY" class="rr-clip__label" />
                        </ui:VisualElement>
                        <ui:VisualElement class="rr-clip rr-clip--fx" style="left: 66%; width: 24%;">
                            <ui:Label text="LOWERTHIRD" class="rr-clip__label" />
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="rr-track-tail">
                        <ui:Label text="OPACITY" class="rr-track-tail__label rr-mono" />
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement class="rr-track">
                    <ui:VisualElement class="rr-track-head">
                        <ui:Toggle value="true" class="rr-fx-toggle" />
                        <ui:Label text="AUD 1" class="rr-track-name rr-mono" />
                    </ui:VisualElement>
                    <ui:VisualElement class="rr-track-lane">
                        <ui:VisualElement class="rr-clip rr-clip--audio" style="left: 0; width: 82%;">
                            <ui:Label text="MASTER" class="rr-clip__label" />
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="rr-track-tail">
                        <ui:Label text="FADE" class="rr-track-tail__label rr-mono" />
                        <RewriteReality.RrIcon icon="SpeakerOn" class="rr-icon rr-track-icon" />
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement class="rr-track">
                    <ui:VisualElement class="rr-track-head">
                        <ui:Toggle value="true" class="rr-fx-toggle" />
                        <ui:Label text="AUD 2" class="rr-track-name rr-mono rr-track-name--off" />
                    </ui:VisualElement>
                    <ui:VisualElement class="rr-track-lane">
                        <ui:VisualElement class="rr-clip rr-clip--audio" style="left: 14%; width: 10%;">
                            <ui:Label text="SFX" class="rr-clip__label" />
                        </ui:VisualElement>
                        <ui:VisualElement class="rr-clip rr-clip--audio" style="left: 40%; width: 12%;">
                            <ui:Label text="SFX" class="rr-clip__label" />
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="rr-track-tail">
                        <RewriteReality.RrIcon icon="SpeakerMute" class="rr-icon rr-track-icon" />
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement class="rr-playhead" style="left: 40%;" />
            </ui:VisualElement>
            <ui:VisualElement name="rr-tl-short" class="rr-tl-short" style="display: none;">
                <ui:VisualElement class="rr-tl-keyrow">
                    <ui:Label text="KEY" class="rr-tl-keyrow__label" />
                    <ui:Button name="rr-short-pad" text="PAD 1" class="rr-short-pad rr-mono" />
                    <ui:Label text="hold = top layer · release = back to song" class="rr-tl-keyrow__hint rr-mono" />
                </ui:VisualElement>
                <ui:VisualElement name="rr-short-lane" class="rr-track rr-short-lane">
                    <ui:VisualElement class="rr-track-head">
                        <ui:Button name="rr-short-hold" class="rr-short-hold">
                            <RewriteReality.RrIcon icon="Zap" />
                        </ui:Button>
                        <ui:Label text="VID 1" class="rr-track-name rr-mono" />
                    </ui:VisualElement>
                    <ui:VisualElement class="rr-track-lane">
                        <ui:VisualElement name="rr-short-clip" class="rr-clip rr-clip--fx" style="left: 0; width: 26%;">
                            <ui:Label text="TRACK A" class="rr-clip__label" />
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="rr-bottom-bar" class="rr-bottom-bar">
            <ui:VisualElement class="rr-mode-switch">
                <ui:VisualElement name="rr-mode-edit" class="rr-mode-opt rr-mode-opt--active">
                    <ui:VisualElement class="rr-mode-opt__dot" />
                    <ui:Label text="準備 EDIT" />
                </ui:VisualElement>
                <ui:VisualElement name="rr-mode-live" class="rr-mode-opt">
                    <ui:VisualElement class="rr-mode-opt__dot" />
                    <ui:Label text="本番 LIVE" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="rr-divider" />
            <ui:VisualElement name="rr-page-tabs" class="rr-page-tabs">
                <ui:Label name="rr-tab-perform" text="PERFORM" class="rr-page-tab rr-stage-source rr-page-tab--active" />
                <ui:Label name="rr-tab-mapping" text="MAPPING" class="rr-page-tab rr-stage-tracking" />
            </ui:VisualElement>
            <ui:VisualElement class="rr-spacer" />
            <ui:Label text="frame 4.2ms · gc 0.3ms" class="rr-perf rr-mono" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
